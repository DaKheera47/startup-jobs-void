{
    "name": "startup-jobs-scraper",
    "version": "0.0.2",
    "type": "module",
    "description": "Node.js and TypeScript scraper library for startup.jobs job listings, remote jobs, and enriched job details, with a matching Apify Actor.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "startupjobs",
        "startup-jobs",
        "startup.jobs",
        "startup jobs",
        "jobs",
        "job listings",
        "job scraper",
        "startup job scraper",
        "startup jobs api",
        "remote jobs",
        "remote job scraper",
        "scraper",
        "algolia",
        "playwright",
        "crawlee",
        "apify",
        "apify actor",
        "typescript"
    ],
    "homepage": "https://github.com/DaKheera47/startup-jobs-void#readme",
    "bugs": {
        "url": "https://github.com/DaKheera47/startup-jobs-void/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DaKheera47/startup-jobs-void.git"
    },
    "engines": {
        "node": ">=20"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "apify": "^3.7.0",
        "camoufox-js": "^0.9.0",
        "crawlee": "^3.0.0",
        "playwright": "*"
    },
    "devDependencies": {
        "@apify/tsconfig": "^0.1.0",
        "@types/fs-extra": "^11",
        "@types/node": "^24.0.0",
        "fs-extra": "^11.3.0",
        "tsx": "^4.4.0",
        "typescript": "~5.9.0"
    },
    "scripts": {
        "build": "tsc",
        "prepack": "npm run build",
        "test": "node --import tsx --test test/**/*.test.ts",
        "actor:start": "node dist/main.js",
        "actor:start:dev": "tsx src/main.ts",
        "browsers:install": "camoufox-js fetch",
        "algolia:extract": "tsx src/extractAlgolia.ts"
    },
    "author": "ssarfaraz",
    "license": "ISC"
}
